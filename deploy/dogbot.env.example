# DogBot 唯一用户配置文件
# 正常情况下你不需要修改 compose/ 目录中的文件
# 部署入口：
#   ./deploy_stack.sh
# 停止入口：
#   ./stop_stack.sh

# =========================
# Claude 容器基础配置
# =========================
CLAUDE_CONTAINER_NAME=claude-runner
CLAUDE_IMAGE_NAME=dogbot/claude-runner:local
CLAUDE_CODE_VERSION=2.1.104

# =========================
# 工作目录与状态目录
# AGENT_WORKSPACE_DIR: 给 Agent 读写的业务工作目录
# AGENT_STATE_DIR: 保存会话、日志、平台状态、数据库等
# 推荐把运行态目录集中在同一个 runtime 根目录下
# SESSION_DB_PATH: Claude session 映射数据库
# HISTORY_DB_PATH: history ingest / retrieval 数据库
# DOGBOT_CLAUDE_PROMPT_ROOT: 运行时 Claude prompt 根目录；部署脚本会把仓库内的 claude-prompt/ 同步到这里
# =========================
AGENT_WORKSPACE_DIR=/srv/dogbot/runtime/agent-workspace
AGENT_STATE_DIR=/srv/dogbot/runtime/agent-state
SESSION_DB_PATH=/srv/dogbot/runtime/agent-state/runner.db
HISTORY_DB_PATH=/srv/dogbot/runtime/agent-state/history.db
DOGBOT_CLAUDE_PROMPT_ROOT=/srv/dogbot/runtime/agent-state/claude-prompt

# =========================
# agent-runner 基础配置
# AGENT_RUNNER_BIND_ADDR: QQ / 微信平台事件直连入口
# DEFAULT_TIMEOUT_SECS: 默认单次执行超时
# MAX_TIMEOUT_SECS: 允许的最大超时上限
# =========================
AGENT_RUNNER_BIND_ADDR=127.0.0.1:8787
DEFAULT_TIMEOUT_SECS=120
MAX_TIMEOUT_SECS=300

# =========================
# 并发、队列、限流
# =========================
MAX_CONCURRENT_RUNS=10
MAX_QUEUE_DEPTH=20
GLOBAL_RATE_LIMIT_PER_MINUTE=10
USER_RATE_LIMIT_PER_MINUTE=3
CONVERSATION_RATE_LIMIT_PER_MINUTE=5

# =========================
# Claude 通过容器内 Bifrost 访问模型
# Claude 自己只看到本地 Bifrost 和 dummy key
# BIFROST_UPSTREAM_* 只定义容器内 Bifrost 要访问的宿主机 api-proxy
# 真实模型地址、真实 token 和可选 model rewrite 都放在 API_PROXY_UPSTREAM_*
# ANTHROPIC_BASE_URL 和 ANTHROPIC_API_KEY 通常不需要修改
# =========================
ANTHROPIC_BASE_URL=http://127.0.0.1:8080/anthropic
ANTHROPIC_API_KEY=dummy
BIFROST_PORT=8080
BIFROST_PROVIDER_NAME=primary
BIFROST_MODEL=primary/model-id
BIFROST_UPSTREAM_PROVIDER_TYPE=anthropic
BIFROST_UPSTREAM_BASE_URL=http://host.docker.internal:9000
BIFROST_UPSTREAM_API_KEY=local-proxy-token

# =========================
# agent-runner api-proxy
# 真实上游地址和 token 只保留在宿主机，不进入 claude-runner 容器
# API_PROXY_UPSTREAM_MODEL 可选；填写后会在 /v1/messages 上覆盖请求中的 model
# =========================
API_PROXY_BIND_ADDR=0.0.0.0:9000
API_PROXY_AUTH_TOKEN=local-proxy-token
API_PROXY_UPSTREAM_BASE_URL=https://example.com
API_PROXY_UPSTREAM_TOKEN=replace-me
API_PROXY_UPSTREAM_AUTH_HEADER=x-api-key
API_PROXY_UPSTREAM_AUTH_SCHEME=
API_PROXY_UPSTREAM_MODEL=

# =========================
# NapCat HTTP API
# NAPCAT_ACCESS_TOKEN 可选，若 NapCat 配了鉴权则填写
# =========================
NAPCAT_API_BASE_URL=http://127.0.0.1:3001
# NAPCAT_ACCESS_TOKEN=

# =========================
# 平台身份配置
# PLATFORM_QQ_BOT_ID: NapCat onebot11_<bot_id>.json 配置文件名后缀
# PLATFORM_WECHATPADPRO_BOT_MENTION_NAMES: 多个名称可用逗号分隔
# =========================
PLATFORM_QQ_ACCOUNT_ID=qq:bot_uin:unknown
PLATFORM_QQ_BOT_ID=
PLATFORM_WECHATPADPRO_ACCOUNT_ID=wechatpadpro:account:unknown
PLATFORM_WECHATPADPRO_BOT_MENTION_NAMES=DogDu

# =========================
# Claude 容器资源限制
# CLAUDE_CONTAINER_DISK_GB 只是目标值，不一定在宿主机上形成硬限制
# =========================
CLAUDE_CONTAINER_CPU_CORES=4
CLAUDE_CONTAINER_MEMORY_MB=4096
CLAUDE_CONTAINER_DISK_GB=50
CLAUDE_CONTAINER_PIDS_LIMIT=256

# =========================
# 日志和 PID 文件
# =========================
AGENT_RUNNER_LOG_DIR=/srv/dogbot/runtime/agent-state/logs
AGENT_RUNNER_PID_FILE=/srv/dogbot/runtime/agent-state/agent-runner.pid

# =========================
# 容器代理配置（可选）
# 这些变量会注入 claude-runner / NapCat / WeChatPadPro 容器
# 如果代理运行在宿主机本地，请使用 host.docker.internal:<port>，不要写 127.0.0.1
# 若 claude-runner 需要访问宿主机上的本地代理，并且 APPLY_NETWORK_POLICY=1，
# 还需要额外放行对应端口，或临时关闭 APPLY_NETWORK_POLICY
# =========================
HTTP_PROXY=
HTTPS_PROXY=
ALL_PROXY=
NO_PROXY=

# =========================
# NapCat 配置
# NAPCAT_QQ_DIR: QQ 登录态目录
# NAPCAT_CONFIG_DIR: NapCat 配置目录
# =========================
# ENABLE_QQ: 无参数运行 deploy_stack.sh 时，QQ 的默认选择
ENABLE_QQ=1
NAPCAT_IMAGE=mlikiowa/napcat-docker:latest
NAPCAT_CONTAINER_NAME=napcat
NAPCAT_WEBUI_PORT=6099
NAPCAT_ONEBOT_PORT=3001
NAPCAT_UID=1000
NAPCAT_GID=1000
NAPCAT_QQ_DIR=/srv/dogbot/runtime/agent-state/napcat-qq
NAPCAT_CONFIG_DIR=/srv/dogbot/runtime/agent-state/napcat-config
NAPCAT_LOGIN_OUTPUT_DIR=/srv/dogbot/runtime/agent-state/napcat-login

# =========================
# WeChatPadPro 总开关
# ENABLE_WECHATPADPRO=1 时会启动微信相关容器
# =========================
# ENABLE_WECHATPADPRO: 无参数运行 deploy_stack.sh 时，微信的默认选择
ENABLE_WECHATPADPRO=0
WECHATPADPRO_IMAGE=wechatpadpro/wechatpadpro:latest
WECHATPADPRO_CONTAINER_NAME=wechatpadpro
WECHATPADPRO_HOST_PORT=38849
WECHATPADPRO_ADMIN_KEY=change-me
WECHATPADPRO_DATA_DIR=/srv/dogbot/runtime/agent-state/wechatpadpro-data/data

# =========================
# WeChatPadPro MySQL
# =========================
WECHATPADPRO_MYSQL_CONTAINER_NAME=wechatpadpro_mysql
WECHATPADPRO_MYSQL_ROOT_PASSWORD=change-me-root
WECHATPADPRO_MYSQL_DATABASE=weixin
WECHATPADPRO_MYSQL_USER=weixin
WECHATPADPRO_MYSQL_PASSWORD=change-me-db
WECHATPADPRO_MYSQL_PORT=3306
WECHATPADPRO_MYSQL_DIR=/srv/dogbot/runtime/agent-state/wechatpadpro-data/mysql

# =========================
# WeChatPadPro Redis
# =========================
WECHATPADPRO_REDIS_CONTAINER_NAME=wechatpadpro_redis
WECHATPADPRO_REDIS_PORT=6379
WECHATPADPRO_REDIS_DB=0
WECHATPADPRO_REDIS_DIR=/srv/dogbot/runtime/agent-state/wechatpadpro-data/redis

# =========================
# WeChatPadPro 业务配置
# WECHATPADPRO_ACCOUNT_KEY 会在登录流程中生成，不必填写
# =========================
WECHATPADPRO_TZ=Asia/Shanghai
WECHATPADPRO_BASE_URL=http://127.0.0.1:38849
WECHATPADPRO_ACCOUNT_KEY=

# =========================
# WeChatPadPro webhook 配置
# WECHATPADPRO_WEBHOOK_URL 是 WeChatPadPro 推送消息的地址
# =========================
WECHATPADPRO_WEBHOOK_URL=http://host.docker.internal:8787/v1/platforms/wechatpadpro/events
WECHATPADPRO_AUTO_CONFIGURE_WEBHOOK=1
WECHATPADPRO_WEBHOOK_INCLUDE_SELF_MESSAGE=false
# WECHATPADPRO_WEBHOOK_SECRET=
WECHATPADPRO_LOGIN_OUTPUT_DIR=/srv/dogbot/runtime/agent-state/wechatpadpro-login
WECHATPADPRO_REQUIRE_MENTION_IN_GROUP=1

# =========================
# 其他
# APPLY_NETWORK_POLICY=1 时会给 Claude 容器应用宿主机网络限制
# API_PROXY_PORT 需要和 API_PROXY_BIND_ADDR 使用的端口保持一致
# =========================
API_PROXY_PORT=9000
APPLY_NETWORK_POLICY=1
