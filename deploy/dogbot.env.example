# DogBot deployment config template.
#
# Copy this file before editing:
#   cp deploy/dogbot.env.example deploy/dogbot.env
#
# Normal deployment commands:
#   ./deploy_stack.sh
#   ./stop_stack.sh
#
# Most values can stay at their defaults. The sections marked "CHANGE" are the
# ones you should review for a real deployment.

# =============================================================================
# Claude runner image
# =============================================================================
# CHANGE if you need a pinned Claude Code version for reproducibility.
# "latest" is convenient while model-provider compatibility is moving quickly.
CLAUDE_CONTAINER_NAME=claude-runner
CLAUDE_IMAGE_NAME=dogbot/claude-runner:local
CLAUDE_CODE_VERSION=latest

# =============================================================================
# Runtime directories
# =============================================================================
# CHANGE these paths for your host. Use absolute paths.
#
# AGENT_WORKSPACE_DIR:
#   Mounted into claude-runner as /workspace. Agent-created files live here.
#
# AGENT_STATE_DIR:
#   Mounted into claude-runner as /state. Logs, Claude state, Bifrost logs,
#   platform login state, and generated runtime scripts live here.
#
# DOGBOT_CLAUDE_PROMPT_ROOT:
#   deploy_stack.sh syncs ./claude-prompt into this directory before start.
#   Do not edit this runtime copy directly; edit ./claude-prompt instead.
AGENT_WORKSPACE_DIR=/srv/dogbot/runtime/agent-workspace
AGENT_STATE_DIR=/srv/dogbot/runtime/agent-state
DOGBOT_CLAUDE_PROMPT_ROOT=/srv/dogbot/runtime/agent-state/claude-prompt

# =============================================================================
# PostgreSQL
# =============================================================================
# CHANGE passwords before exposing this outside a local machine.
#
# DogBot is Postgres-only. Old sqlite runner.db/history.db files are ignored.
# agent-runner uses the admin user to initialize schema and write messages.
# Claude receives only POSTGRES_AGENT_READER_DATABASE_URL plus a short run token;
# Postgres RLS and read-only views enforce history isolation.
#
# POSTGRES_PORT is the host port. The container still listens on 5432.
POSTGRES_CONTAINER_NAME=dogbot-postgres
POSTGRES_IMAGE=postgres:15
POSTGRES_DATA_DIR=/srv/dogbot/runtime/agent-state/postgres
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=15432
POSTGRES_DB=dogbot
POSTGRES_ADMIN_USER=dogbot_admin
POSTGRES_ADMIN_PASSWORD=change-me
POSTGRES_AGENT_READER_USER=dogbot_agent_reader
POSTGRES_AGENT_READER_PASSWORD=change-me-reader
POSTGRES_AGENT_READER_DATABASE_URL=postgres://dogbot_agent_reader:change-me-reader@postgres:5432/dogbot

# Optional. Leave empty to let agent-runner build the admin connection string
# from POSTGRES_HOST / POSTGRES_PORT / POSTGRES_DB / POSTGRES_ADMIN_*.
DATABASE_URL=

# History read grants are short lived. 1800 seconds = 30 minutes.
HISTORY_RUN_TOKEN_TTL_SECS=1800
HISTORY_RETENTION_DAYS=180

# Optional. Comma-separated actor ids that can read cross-session history from
# private chat. Example: DOGBOT_ADMIN_ACTOR_IDS=qq:user:123,wechatpadpro:user:wxid_x
DOGBOT_ADMIN_ACTOR_IDS=

# =============================================================================
# agent-runner HTTP service
# =============================================================================
# CHANGE port if it conflicts.
#
# Containers call this through host.docker.internal, so do not bind only to
# 127.0.0.1 unless you also change platform callback networking.
AGENT_RUNNER_BIND_ADDR=0.0.0.0:8787

# =============================================================================
# Scheduler
# =============================================================================
# MAX_CONCURRENT_RUNS is global concurrency.
# Each conversation still runs one task at a time; later messages queue FIFO.
MAX_CONCURRENT_RUNS=10
MAX_QUEUE_DEPTH=20

# =============================================================================
# Claude Code -> Bifrost -> agent-runner api-proxy
# =============================================================================
# Usually do not change ANTHROPIC_BASE_URL or ANTHROPIC_API_KEY.
# Claude Code only talks to the in-container Bifrost endpoint and sees a dummy
# key. Bifrost then calls the host api-proxy using BIFROST_UPSTREAM_API_KEY.
ANTHROPIC_BASE_URL=http://127.0.0.1:8080/anthropic
ANTHROPIC_API_KEY=dummy
BIFROST_PORT=8080
BIFROST_PROVIDER_NAME=primary

# CHANGE to the model alias Claude Code should request inside the container.
# Examples:
#   BIFROST_MODEL=primary/deepseek-v4-pro
#   BIFROST_MODEL=primary/gpt-5
BIFROST_MODEL=primary/model-id

# Keep these as local-proxy settings unless you know you need a different route.
BIFROST_UPSTREAM_PROVIDER_TYPE=anthropic
BIFROST_UPSTREAM_BASE_URL=http://host.docker.internal:9000
BIFROST_UPSTREAM_API_KEY=local-proxy-token

# =============================================================================
# Host api-proxy -> real upstream model provider
# =============================================================================
# CHANGE these for your model provider. This is where the real key belongs.
#
# API_PROXY_AUTH_TOKEN must match BIFROST_UPSTREAM_API_KEY.
# API_PROXY_UPSTREAM_MODEL is optional; set it when the upstream model id differs
# from BIFROST_MODEL. It is commonly needed for provider-specific suffixes.
API_PROXY_BIND_ADDR=0.0.0.0:9000
API_PROXY_AUTH_TOKEN=local-proxy-token
API_PROXY_UPSTREAM_BASE_URL=https://example.com
API_PROXY_UPSTREAM_TOKEN=replace-me
API_PROXY_UPSTREAM_AUTH_HEADER=x-api-key
API_PROXY_UPSTREAM_AUTH_SCHEME=
API_PROXY_UPSTREAM_MODEL=

# DeepSeek Anthropic-compatible example:
#   BIFROST_MODEL=primary/deepseek-v4-pro
#   API_PROXY_UPSTREAM_BASE_URL=https://api.deepseek.com/anthropic
#   API_PROXY_UPSTREAM_AUTH_HEADER=x-api-key
#   API_PROXY_UPSTREAM_AUTH_SCHEME=
#   API_PROXY_UPSTREAM_MODEL=deepseek-v4-pro[1m]
#
# Bearer-token provider example:
#   API_PROXY_UPSTREAM_AUTH_HEADER=authorization
#   API_PROXY_UPSTREAM_AUTH_SCHEME=Bearer

# =============================================================================
# NapCat HTTP API
# =============================================================================
# NAPCAT_API_BASE_URL is used by agent-runner to send QQ messages.
# NAPCAT_HTTP_CLIENT_URL is written into NapCat config as the event callback.
# If AGENT_RUNNER_BIND_ADDR port changes, update NAPCAT_HTTP_CLIENT_URL too.
NAPCAT_API_BASE_URL=http://127.0.0.1:3001
# NAPCAT_ACCESS_TOKEN=
NAPCAT_HTTP_CLIENT_URL=http://host.docker.internal:8787/v1/platforms/qq/napcat/events

# =============================================================================
# Platform identity
# =============================================================================
# CHANGE when enabling the corresponding platform.
#
# PLATFORM_QQ_BOT_ID:
#   The actual QQ number used by NapCat. Required when ENABLE_QQ=1.
#
# PLATFORM_QQ_ACCOUNT_ID and PLATFORM_WECHATPADPRO_ACCOUNT_ID:
#   Stable isolation keys for session/history. Prefer including the real bot id.
#
# PLATFORM_WECHATPADPRO_BOT_MENTION_NAMES:
#   Names that trigger the bot in WeChat groups. Comma-separated.
PLATFORM_QQ_ACCOUNT_ID=qq:bot_uin:unknown
PLATFORM_QQ_BOT_ID=
PLATFORM_WECHATPADPRO_ACCOUNT_ID=wechatpadpro:account:unknown
PLATFORM_WECHATPADPRO_BOT_MENTION_NAMES=DogDu

# =============================================================================
# Claude container resource limits
# =============================================================================
# Disk limit is a target used by runtime policy code; Docker may not enforce it
# as a hard quota on every host filesystem.
CLAUDE_CONTAINER_CPU_CORES=4
CLAUDE_CONTAINER_MEMORY_MB=4096
CLAUDE_CONTAINER_DISK_GB=50
CLAUDE_CONTAINER_PIDS_LIMIT=256

# =============================================================================
# agent-runner logs and pid
# =============================================================================
AGENT_RUNNER_LOG_DIR=/srv/dogbot/runtime/agent-state/logs
AGENT_RUNNER_PID_FILE=/srv/dogbot/runtime/agent-state/agent-runner.pid

# =============================================================================
# Optional container proxy
# =============================================================================
# These values are injected into claude-runner, NapCat, and WeChatPadPro.
# If your proxy runs on the host, use host.docker.internal:<port>, not 127.0.0.1.
HTTP_PROXY=
HTTPS_PROXY=
ALL_PROXY=
NO_PROXY=

# =============================================================================
# QQ / NapCat
# =============================================================================
# ENABLE_QQ is used by ./deploy_stack.sh when no explicit --qq/--no-qq flag is
# provided. PLATFORM_QQ_BOT_ID is still required when QQ is enabled.
ENABLE_QQ=1
NAPCAT_IMAGE=mlikiowa/napcat-docker:latest
NAPCAT_CONTAINER_NAME=napcat
NAPCAT_WEBUI_PORT=6099
NAPCAT_ONEBOT_PORT=3001
NAPCAT_UID=1000
NAPCAT_GID=1000
NAPCAT_QQ_DIR=/srv/dogbot/runtime/agent-state/napcat-qq
NAPCAT_CONFIG_DIR=/srv/dogbot/runtime/agent-state/napcat-config
NAPCAT_LOGIN_OUTPUT_DIR=/srv/dogbot/runtime/agent-state/napcat-login

# =============================================================================
# WeChat / WeChatPadPro
# =============================================================================
# ENABLE_WECHATPADPRO is used by ./deploy_stack.sh when no explicit
# --wechat/--no-wechat flag is provided.
ENABLE_WECHATPADPRO=0
WECHATPADPRO_IMAGE=wechatpadpro/wechatpadpro:latest
WECHATPADPRO_CONTAINER_NAME=wechatpadpro
WECHATPADPRO_HOST_PORT=38849

# CHANGE before enabling WeChatPadPro.
WECHATPADPRO_ADMIN_KEY=change-me
WECHATPADPRO_DATA_DIR=/srv/dogbot/runtime/agent-state/wechatpadpro-data/data

# =============================================================================
# WeChatPadPro MySQL
# =============================================================================
# CHANGE both passwords before enabling WeChatPadPro.
WECHATPADPRO_MYSQL_CONTAINER_NAME=wechatpadpro_mysql
WECHATPADPRO_MYSQL_ROOT_PASSWORD=change-me-root
WECHATPADPRO_MYSQL_DATABASE=weixin
WECHATPADPRO_MYSQL_USER=weixin
WECHATPADPRO_MYSQL_PASSWORD=change-me-db
WECHATPADPRO_MYSQL_PORT=3306
WECHATPADPRO_MYSQL_DIR=/srv/dogbot/runtime/agent-state/wechatpadpro-data/mysql

# =============================================================================
# WeChatPadPro Redis
# =============================================================================
WECHATPADPRO_REDIS_CONTAINER_NAME=wechatpadpro_redis
WECHATPADPRO_REDIS_PORT=6379
WECHATPADPRO_REDIS_DB=0
WECHATPADPRO_REDIS_DIR=/srv/dogbot/runtime/agent-state/wechatpadpro-data/redis

# =============================================================================
# WeChatPadPro account and webhook
# =============================================================================
# WECHATPADPRO_ACCOUNT_KEY is generated/refreshed by the login script and written
# back to deploy/dogbot.env. Leave it empty in the template.
WECHATPADPRO_TZ=Asia/Shanghai
WECHATPADPRO_BASE_URL=http://127.0.0.1:38849
WECHATPADPRO_ACCOUNT_KEY=

# If AGENT_RUNNER_BIND_ADDR port changes, update this callback URL too.
WECHATPADPRO_WEBHOOK_URL=http://host.docker.internal:8787/v1/platforms/wechatpadpro/events
WECHATPADPRO_AUTO_CONFIGURE_WEBHOOK=1
WECHATPADPRO_WEBHOOK_INCLUDE_SELF_MESSAGE=false
# WECHATPADPRO_WEBHOOK_SECRET=
WECHATPADPRO_LOGIN_OUTPUT_DIR=/srv/dogbot/runtime/agent-state/wechatpadpro-login

# 1 = WeChat group messages must mention one of PLATFORM_WECHATPADPRO_BOT_MENTION_NAMES.
# 0 = group text can trigger without a mention.
WECHATPADPRO_REQUIRE_MENTION_IN_GROUP=1

# =============================================================================
# Network policy
# =============================================================================
# APPLY_NETWORK_POLICY=1 restricts claude-runner network access from the host.
# API_PROXY_PORT must match API_PROXY_BIND_ADDR's port.
API_PROXY_PORT=9000
APPLY_NETWORK_POLICY=1
